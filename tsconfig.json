{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "@playwright/test"],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "tests",
    "pages",
    "fixtures",
    "utils",
    "hooks",
    "api-client",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "reports",
    "dist"
  ]
}
